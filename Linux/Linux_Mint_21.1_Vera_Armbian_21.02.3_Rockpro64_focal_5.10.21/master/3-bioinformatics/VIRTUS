#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

git_clone_with_retry() {
    local repo_url="$1"
    local dest_dir="$2"
    local label="$3"
    local branch="$4"
    local max_attempts=5
    local attempt=1

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Cloning $label (attempt $attempt of $max_attempts)..."
        if [ -n "$branch" ]; then
            su -c "rm -rf '$dest_dir' && git clone --branch '$branch' '$repo_url' '$dest_dir'" "$user_name" && return 0
        else
            su -c "rm -rf '$dest_dir' && git clone '$repo_url' '$dest_dir'" "$user_name" && return 0
        fi
        attempt=$((attempt + 1))
    done

    echo "${r}ERROR: Failed to clone $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "VIRTUS"
echo "*******************${w}"
echo

pip3 install --upgrade pip || exit 1
pip3 install cwltool cwlref-runner numpy pandas scipy statsmodels seaborn || {
    echo "${r}ERROR: Failed to install required Python packages for VIRTUS.${w}"
    exit 1
}

rm -rf /home/"$user_name"/VIRTUS /home/"$user_name"/VIRTUS2

git_clone_with_retry "https://github.com/yyoshiaki/VIRTUS2.git" "/home/$user_name/VIRTUS2" "VIRTUS2" "v2.0.2"
git_clone_with_retry "https://github.com/yyoshiaki/VIRTUS" "/home/$user_name/VIRTUS" "VIRTUS" ""

sudo apt-get remove -y docker docker-engine docker.io containerd runc
sudo apt-get update || exit 1
sudo apt-get install -y ca-certificates curl gnupg || exit 1
sudo install -m 0755 -d /etc/apt/keyrings || exit 1
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --always-trust --dearmor -o /etc/apt/keyrings/docker.gpg || exit 1
sudo chmod a+r /etc/apt/keyrings/docker.gpg

echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

VERSION_CODENAME=$(awk '{print $5}' /etc/apt/sources.list.d/docker.list)
UBUNTU_CODENAME=$(grep -i '^UBUNTU_CODENAME=' /etc/os-release | awk -F= '{print $2}')
sudo sed -i "s/$VERSION_CODENAME/$UBUNTU_CODENAME/" /etc/apt/sources.list.d/docker.list

sudo apt-get update || exit 1
sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin || {
    echo "${r}ERROR: Failed to install Docker.${w}"
    exit 1
}

/home/$user_name/VIRTUS/bin/VIRTUS.PE.cwl --help | grep VIRTUS | grep v > VIRTUS_VER
/home/$user_name/VIRTUS2/bin/VIRTUS.PE.cwl --help | grep VIRTUS | grep v > VIRTUS2_VER

VIRTUS_VER=$(cat VIRTUS_VER)
VIRTUS2_VER=$(cat VIRTUS2_VER)

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
echo "VIRTUS: $VIRTUS_VER"
echo "VIRTUS2: $VIRTUS2_VER"
echo "${g}----------------------------${w}"

rm -f VIRTUS_VER VIRTUS2_VER
