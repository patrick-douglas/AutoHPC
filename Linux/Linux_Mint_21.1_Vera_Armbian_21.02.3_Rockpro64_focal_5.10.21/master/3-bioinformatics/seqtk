#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

git_clone_with_retry() {
    local repo_url="$1"
    local dest_dir="$2"
    local label="$3"
    local max_attempts=5
    local attempt=1

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Cloning $label (attempt $attempt of $max_attempts)..."
        su -c "rm -rf '$dest_dir' && git clone '$repo_url' '$dest_dir'" "$user_name" && return 0
        attempt=$((attempt + 1))
    done

    echo "${r}ERROR: Failed to clone $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

seqtk_path="/home/$user_name/seqtk"
seqtk_URL="https://github.com/lh3/seqtk.git"

git_clone_with_retry "$seqtk_URL" "$seqtk_path" "seqtk"

su -c "cd '$seqtk_path' && make" "$user_name" || {
    echo "${r}ERROR: seqtk compilation step failed.${w}"
    exit 1
}
cd "$seqtk_path" && sudo make install || {
    echo "${r}ERROR: seqtk installation step failed.${w}"
    exit 1
}

rm -rf "$seqtk_path"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
seqtk 2>&1 | grep Version
echo "${g}----------------------------${w}"
