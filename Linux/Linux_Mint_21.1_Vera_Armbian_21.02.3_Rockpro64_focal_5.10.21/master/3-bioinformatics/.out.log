> install_if_missing <- function(pkgs) {
+   for (p in pkgs) {
+     p <- trimws(p)
+     if (!nzchar(p)) next
+ 
+     if (!requireNamespace(p, quietly = TRUE)) {
+       message("Installing (CRAN): ", p)
+       install.packages(p, dependencies = TRUE)
+     } else {
+       message("Already installed: ", p)
+     }
+   }
+ }
