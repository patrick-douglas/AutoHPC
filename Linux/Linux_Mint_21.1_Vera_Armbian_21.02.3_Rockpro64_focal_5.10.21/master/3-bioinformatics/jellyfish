#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

download_with_retry() {
    local url="$1"; local output="$2"; local label="$3"
    local max_attempts=5; local attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then return 0; fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done
    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "Jellyfish"
echo "*******************${w}"

jellyfish_path="/home/$user_name/jellyfish-2.3.0"
jellyfish_tar="/home/$user_name/jellyfish-2.3.0.tar.gz"
jellyfish_url="https://github.com/gmarcais/Jellyfish/releases/download/v2.3.0/jellyfish-2.3.0.tar.gz"

download_with_retry "$jellyfish_url" "$jellyfish_tar" "Jellyfish"

su -c "cd ~/ && tar -zxf '$jellyfish_tar'" "$user_name" || exit 1
su -c "cd '$jellyfish_path' && ./configure" "$user_name" || exit 1
su -c "cd '$jellyfish_path' && make -j '$threads'" "$user_name" || exit 1
cd "$jellyfish_path" && sudo make install -j "$threads" || exit 1

rm -rf "$jellyfish_path" "$jellyfish_tar"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
jellyfish --version
echo "${g}----------------------------${w}"
