#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

# BCFtools
echo "${y}*******************"
echo "BCFtools"
echo "*******************${w}"

bcf_tools_tar="/home/$user_name/bcftools-1.9.tar.bz2"
bcf_tools_path="/home/$user_name/bcftools-1.9"
bcf_tools_url="https://github.com/samtools/bcftools/releases/download/1.9/bcftools-1.9.tar.bz2"

max_attempts=5
attempt=1
download_success=0

echo "${y}Downloading BCFtools source package...${w}"

while [ "$attempt" -le "$max_attempts" ]; do
    echo "Attempt $attempt of $max_attempts..."

    su -c "cd ~/ && wget -O '$bcf_tools_tar' '$bcf_tools_url'" "$user_name"
    wget_exit=$?

    if [ "$wget_exit" -eq 0 ] && [ -s "$bcf_tools_tar" ]; then
        echo "${g}Download completed successfully.${w}"
        download_success=1
        break
    else
        echo "${r}Download failed on attempt $attempt.${w}"
        rm -f "$bcf_tools_tar"
    fi

    attempt=$((attempt + 1))
done

if [ "$download_success" -ne 1 ]; then
    echo "${r}ERROR: Failed to download BCFtools after $max_attempts attempts. Installation aborted.${w}"
    exit 1
fi

su -c "cd ~/ && tar -xjf '$bcf_tools_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the BCFtools source archive.${w}"
    exit 1
}

su -c "cd '$bcf_tools_path' && ./configure --prefix=/usr/local" "$user_name" || {
    echo "${r}ERROR: BCFtools configuration step failed.${w}"
    exit 1
}

su -c "cd '$bcf_tools_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: BCFtools compilation step failed.${w}"
    exit 1
}

cd "$bcf_tools_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: BCFtools installation step failed.${w}"
    exit 1
}

if [ ! -x /usr/local/bin/bcftools ]; then
    echo "${r}ERROR: BCFtools binary was not found in /usr/local/bin after installation.${w}"
    exit 1
fi

sudo ln -sf /usr/local/bin/bcftools /usr/bin/bcftools || {
    echo "${r}ERROR: Failed to create the bcftools symlink in /usr/bin.${w}"
    exit 1
}

rm -rf "$bcf_tools_path" "$bcf_tools_tar"

echo "${g}"
echo "---------------------------------------------------"
echo "          Currently installed version:"
echo "---------------------------------------------------${w}"
bcftools -v | grep bcftools -A 1
echo "${g}---------------------------------------------------${w}"
