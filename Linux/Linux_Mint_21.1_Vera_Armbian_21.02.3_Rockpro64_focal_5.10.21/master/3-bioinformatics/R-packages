#!/usr/bin/env bash
set -euo pipefail

# ==========================================
# Este script é executado através de um script primário
# ==========================================

# Colors (safe if not a TTY)
w=$(tput sgr0 2>/dev/null || true)
r=$(tput setaf 1 2>/dev/null || true)
g=$(tput setaf 2 2>/dev/null || true)
y=$(tput setaf 3 2>/dev/null || true)

threads="$(nproc 2>/dev/null || echo 1)"

# Logs
out_log=".out.log"
err_log=".err.log"
keep_logs=0

usage() {
  echo "USAGE: $0 [-o] [-h]"
  echo "  -o   keep installation logs ($out_log / $err_log)"
  echo "  -h   show this help"
}

while getopts ":oh" opt; do
  case "$opt" in
    o) keep_logs=1 ;;
    h) usage; exit 0 ;;
    \?) echo "${r}Error:${w} invalid option -$OPTARG"; usage; exit 1 ;;
  esac
done

rm -f "$out_log" "$err_log"

# Tee stdout/stderr to files while still printing
exec 1> >(tee -a "$out_log") 2> >(tee -a "$err_log" >&2)

cleanup() {
  if [[ "$keep_logs" -eq 0 ]]; then
    rm -f "$out_log" "$err_log"
  else
    echo ""
    echo "${y}Logs kept:${w} $out_log  $err_log"
  fi
}
trap cleanup EXIT

banner() {
  echo "${g}************************************************"
  echo "  ${w}$1${g}"
  echo "************************************************${w}"
}

sudo_cmd() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    sudo "$@"
  else
    "$@"
  fi
}

# Use apt-fast if available, else apt-get
APT_BIN="apt-get"
if command -v apt-fast >/dev/null 2>&1; then
  APT_BIN="apt-fast"
fi

# ==========================================
# System dependencies
# ==========================================
banner "Installing required system libraries"
echo "NOTE: Use -o to keep installation logs"
echo ""

sudo_cmd "$APT_BIN" update -y

# Unified deps list (Mint/Ubuntu Jammy compatible)
SYS_DEPS=(
  build-essential
  pkg-config
  gcc g++ gfortran
  xorg-dev

  # common R build deps
  libcurl4-openssl-dev
  libssl-dev
  libxml2-dev
  libreadline-dev
  libbz2-dev
  liblzma-dev

  # graphics/fonts (ragg/systemfonts/textshaping)
  libcairo2-dev
  libfreetype6-dev
  libpng-dev
  libtiff5-dev
  libjpeg-dev
  libwebp-dev
  libharfbuzz-dev
  libfribidi-dev
  libfontconfig1-dev
  libgl1-mesa-dev

  # spatial / misc
  libudunits2-dev
  libproj-dev
  libblas-dev
)

sudo_cmd "$APT_BIN" install -y "${SYS_DEPS[@]}"

# ==========================================
# R packages (CRAN + Bioconductor)
# ==========================================
banner "Installing required R packages"
echo ""

R --vanilla - <<'RSCRIPT'
options(repos = c(CRAN = "https://cloud.r-project.org"))

# Use available cores, but don't explode laptops/VMs
try({
  options(Ncpus = max(1L, parallel::detectCores()))
}, silent = TRUE)

install_if_missing <- function(pkgs) {
  for (p in pkgs) {
    p <- trimws(p)
    if (!nzchar(p)) next

    if (!requireNamespace(p, quietly = TRUE)) {
      message("Installing (CRAN): ", p)
      install.packages(p, dependencies = TRUE)
    } else {
      message("Already installed: ", p)
    }
  }
}

# Ensure BiocManager
if (!requireNamespace("BiocManager", quietly = TRUE)) {
  install.packages("BiocManager")
}

# Update CRAN packages without prompting
update.packages(ask = FALSE, checkBuilt = TRUE)

# -------- CRAN packages --------
cran_pkgs <- c(
  "tidyverse",
  "ggplot2",
  "dplyr",
  "ggrepel",
  "devtools",
  "argparse",
  "fastcluster",
  "ape",
  "phytools",
  "gplots",
  "proj4",
  "ragg"
)

install_if_missing(cran_pkgs)

# -------- Bioconductor packages --------
bioc_pkgs <- c(
  "edgeR",
  "limma",
  "Glimma",
  "RCurl",
  "annotate",
  "GenomicRanges",
  "SummarizedExperiment",
  "genefilter",
  "geneplotter",
  "DESeq2",
  "DEXSeq",
  "EBSeq",
  "qvalue",
  "seqLogo",
  "EnhancedVolcano"
)

for (p in bioc_pkgs) {
  p <- trimws(p)
  if (!nzchar(p)) next

  if (!requireNamespace(p, quietly = TRUE)) {
    message("Installing (Bioconductor): ", p)
    BiocManager::install(p, ask = FALSE, update = FALSE)
  } else {
    message("Already installed: ", p)
  }
}
RSCRIPT

# ==========================================
# Report
# ==========================================
banner "Currently installed version"
echo ""

if [[ -x ./R-packages_ver ]]; then
  ./R-packages_ver
else
  echo "${y}Note:${w} ./R-packages_ver not found or not executable; skipping."
fi
