#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo "${r}Error: missing argument ${y}-u <username>${w}"
    echo "$USAGE"
    exit 1
fi

threads=$(nproc)

# Install required libraries
echo "${y}*****************************"
echo "Installing required libraries"
echo "*****************************${w}"
sudo apt-fast install -y build-essential fort77 liblzma-dev libblas-dev gfortran gcc-multilib gobjc++ aptitude libcurl4-openssl-dev libbz2-dev libproj-dev xorg-dev || {
    echo "${r}ERROR: Failed to install required packages with apt-fast.${w}"
    exit 1
}
sudo aptitude install -y libreadline-dev || {
    echo "${r}ERROR: Failed to install libreadline-dev with aptitude.${w}"
    exit 1
}

# R installation/update
echo "${y}*******************"
echo "R Installation"
echo "*******************${w}"

R_path_glob="/home/$user_name/R-*.*.*"
R_tar="R-latest.tar.gz"
R_tar_path="/home/$user_name/$R_tar"
R_url="https://cran.r-project.org/src/base/R-latest.tar.gz"

max_attempts=10
attempt=1
download_success=0

rm -rf $R_path_glob "$R_tar_path"

echo "${y}Downloading R source package...${w}"

while [ "$attempt" -le "$max_attempts" ]; do
    echo "Attempt $attempt of $max_attempts..."

    su -c "cd ~/ && wget -O '$R_tar' '$R_url'" "$user_name"
    wget_exit=$?

    if [ "$wget_exit" -eq 0 ] && [ -s "$R_tar_path" ]; then
        echo "${g}Download completed successfully.${w}"
        download_success=1
        break
    else
        echo "${r}Download failed on attempt $attempt.${w}"
        rm -f "$R_tar_path"
    fi

    attempt=$((attempt + 1))
done

if [ "$download_success" -ne 1 ]; then
    echo "${r}ERROR: Failed to download R after $max_attempts attempts. Installation aborted.${w}"
    exit 1
fi

# Extract
su -c "cd ~/ && tar -zxf '$R_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the R source archive.${w}"
    exit 1
}

rm -rf /home/"$user_name"/R-*.tar.gz

# Find extracted directory
R_path=$(find /home/"$user_name" -maxdepth 1 -type d -name "R-*" | head -n 1)

if [ -z "$R_path" ]; then
    echo "${r}ERROR: Could not locate the extracted R source directory.${w}"
    exit 1
fi

# Configure
su -c "cd '$R_path' && ./configure --with-cairo --enable-R-shlib" "$user_name" || {
    echo "${r}ERROR: R configuration step failed.${w}"
    exit 1
}

# Compile
su -c "cd '$R_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: R compilation step failed.${w}"
    exit 1
}

# Install
cd "$R_path" && sudo make uninstall -j "$threads" || true
cd "$R_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: R installation step failed.${w}"
    exit 1
}

# Fix ownership and cleanup
chown -R "$user_name:$user_name" "/home/$user_name"
rm -rf "$R_path" "$R_tar_path"
cd

# Show installed version
echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
R --version | grep version | grep R
echo "${g}----------------------------${w}"
