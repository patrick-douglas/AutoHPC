#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

# RSEM
echo "${y}*******************"
echo "RSEM"
echo "*******************${w}"

RSEM_path="/home/$user_name/RSEM-master"
RSEM_zip="/home/$user_name/master.zip"
RSEM_url="https://codeload.github.com/deweylab/RSEM/zip/master"

max_attempts=5
attempt=1
download_success=0

echo "${y}Downloading RSEM source package...${w}"

while [ "$attempt" -le "$max_attempts" ]; do
    echo "Attempt $attempt of $max_attempts..."

    su -c "cd ~/ && wget -O '$RSEM_zip' '$RSEM_url'" "$user_name"
    wget_exit=$?

    if [ "$wget_exit" -eq 0 ] && [ -s "$RSEM_zip" ]; then
        echo "${g}Download completed successfully.${w}"
        download_success=1
        break
    else
        echo "${r}Download failed on attempt $attempt.${w}"
        rm -f "$RSEM_zip"
    fi

    attempt=$((attempt + 1))
done

if [ "$download_success" -ne 1 ]; then
    echo "${r}ERROR: Failed to download RSEM after $max_attempts attempts. Installation aborted.${w}"
    exit 1
fi

su -c "cd ~/ && unzip -o '$RSEM_zip' -d ~/" "$user_name" || {
    echo "${r}ERROR: Failed to extract the RSEM source archive.${w}"
    exit 1
}

if [ ! -d "$RSEM_path" ]; then
    echo "${r}ERROR: Could not locate the extracted RSEM source directory.${w}"
    exit 1
fi

su -c "cd '$RSEM_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: RSEM compilation step failed.${w}"
    exit 1
}

su -c "cd '$RSEM_path' && make ebseq -j '$threads'" "$user_name" || {
    echo "${r}ERROR: RSEM EBSeq compilation step failed.${w}"
    exit 1
}

cd "$RSEM_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: RSEM installation step failed.${w}"
    exit 1
}

cd "$RSEM_path" && sudo make ebseq install -j "$threads" || {
    echo "${r}ERROR: RSEM EBSeq installation step failed.${w}"
    exit 1
}

rm -rf "$RSEM_path" "$RSEM_zip"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
rsem-calculate-expression --version
echo "${g}----------------------------${w}"
