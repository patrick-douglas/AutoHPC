#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

download_with_retry() {
    local url="$1"
    local output="$2"
    local label="$3"
    local max_attempts=5
    local attempt=1
    local success=0

    echo "${y}Downloading $label source package...${w}"

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Attempt $attempt of $max_attempts..."

        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        wget_exit=$?

        if [ "$wget_exit" -eq 0 ] && [ -s "$output" ]; then
            echo "${g}Download completed successfully.${w}"
            success=1
            break
        else
            echo "${r}Download failed on attempt $attempt.${w}"
            rm -f "$output"
        fi

        attempt=$((attempt + 1))
    done

    if [ "$success" -ne 1 ]; then
        echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
        exit 1
    fi
}

sudo apt-fast install -y libncurses5-dev libncursesw5-dev || {
    echo "${r}ERROR: Failed to install required ncurses packages.${w}"
    exit 1
}

# BCFtools
echo "${y}*******************"
echo "BCFtools"
echo "*******************${w}"

bcf_tools_tar="/home/$user_name/bcftools-1.14.tar.bz2"
bcf_tools_path="/home/$user_name/bcftools-1.14"
bcf_tools_url="https://github.com/samtools/bcftools/releases/download/1.14/bcftools-1.14.tar.bz2"

download_with_retry "$bcf_tools_url" "$bcf_tools_tar" "BCFtools"

su -c "cd ~/ && tar -xjf '$bcf_tools_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the BCFtools source archive.${w}"
    exit 1
}

su -c "cd '$bcf_tools_path' && ./configure --prefix=/usr/local" "$user_name" || {
    echo "${r}ERROR: BCFtools configuration step failed.${w}"
    exit 1
}

su -c "cd '$bcf_tools_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: BCFtools compilation step failed.${w}"
    exit 1
}

cd "$bcf_tools_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: BCFtools installation step failed.${w}"
    exit 1
}

if [ ! -x /usr/local/bin/bcftools ]; then
    echo "${r}ERROR: BCFtools binary was not found in /usr/local/bin after installation.${w}"
    exit 1
fi

sudo ln -sf /usr/local/bin/bcftools /usr/bin/bcftools || {
    echo "${r}ERROR: Failed to create the bcftools symlink in /usr/bin.${w}"
    exit 1
}

rm -rf "$bcf_tools_path" "$bcf_tools_tar"

# HTSLIB
echo "${y}*******************"
echo "Htslib"
echo "*******************${w}"

HTSLIB_tar="/home/$user_name/htslib-1.14.tar.bz2"
HTSLIB_path="/home/$user_name/htslib-1.14"
HTSLIB_url="https://github.com/samtools/htslib/releases/download/1.14/htslib-1.14.tar.bz2"

download_with_retry "$HTSLIB_url" "$HTSLIB_tar" "HTSLIB"

su -c "cd ~/ && tar -xjf '$HTSLIB_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the HTSLIB source archive.${w}"
    exit 1
}

su -c "cd '$HTSLIB_path' && ./configure --disable-bz2" "$user_name" || {
    echo "${r}ERROR: HTSLIB configuration step failed.${w}"
    exit 1
}

su -c "cd '$HTSLIB_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: HTSLIB compilation step failed.${w}"
    exit 1
}

cd "$HTSLIB_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: HTSLIB installation step failed.${w}"
    exit 1
}

rm -rf "$HTSLIB_path" "$HTSLIB_tar"

# SAMTOOLS
echo "${y}*******************"
echo "Samtools"
echo "*******************${w}"

samtools_path="/home/$user_name/samtools-1.14"
samtools_bz2="/home/$user_name/samtools-1.14.tar.bz2"
samtools_url="https://github.com/samtools/samtools/releases/download/1.14/samtools-1.14.tar.bz2"

download_with_retry "$samtools_url" "$samtools_bz2" "Samtools"

su -c "cd ~/ && tar -xjf '$samtools_bz2'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the Samtools source archive.${w}"
    exit 1
}

su -c "cd '$samtools_path' && ./configure" "$user_name" || {
    echo "${r}ERROR: Samtools configuration step failed.${w}"
    exit 1
}

su -c "cd '$samtools_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: Samtools compilation step failed.${w}"
    exit 1
}

cd "$samtools_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: Samtools installation step failed.${w}"
    exit 1
}

rm -rf "$samtools_path" "$samtools_bz2"

samtools_v=$(samtools --version | grep samtools)

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
bcftools -v | grep bcftools -A 1
echo "$samtools_v"
echo "${g}----------------------------${w}"

echo "${g}"
echo "--------------------------------"
echo "samtools configured successfully"
echo "--------------------------------${w}"
