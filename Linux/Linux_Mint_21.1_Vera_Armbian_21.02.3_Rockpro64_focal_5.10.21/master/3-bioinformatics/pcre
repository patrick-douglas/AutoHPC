#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

# PCRE2
echo "${y}*******************"
echo "pcre2"
echo "*******************${w}"

PCRE2_url="https://github.com/PhilipHazel/pcre2/releases/download/pcre2-10.39/pcre2-10.39.tar.bz2"
PCRE2_path="/home/$user_name/pcre2-10.39"
PCRE2_tar="/home/$user_name/pcre2-10.39.tar.bz2"

max_attempts=10
attempt=1
download_success=0

echo "${y}Downloading PCRE2 source package...${w}"

while [ "$attempt" -le "$max_attempts" ]; do
    echo "Attempt $attempt of $max_attempts..."

    su -c "cd ~/ && wget -O '$PCRE2_tar' '$PCRE2_url'" "$user_name"
    wget_exit=$?

    if [ "$wget_exit" -eq 0 ] && [ -s "$PCRE2_tar" ]; then
        echo "${g}Download completed successfully.${w}"
        download_success=1
        break
    else
        echo "${r}Download failed on attempt $attempt.${w}"
        rm -f "$PCRE2_tar"
    fi

    attempt=$((attempt + 1))
done

if [ "$download_success" -ne 1 ]; then
    echo "${r}ERROR: Failed to download PCRE2 after $max_attempts attempts. Installation aborted.${w}"
    exit 1
fi

su -c "cd ~/ && tar -xvf '$PCRE2_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the PCRE2 source archive.${w}"
    exit 1
}

su -c "cd '$PCRE2_path' && ./configure --enable-utf8" "$user_name" || {
    echo "${r}ERROR: PCRE2 configuration step failed.${w}"
    exit 1
}

su -c "cd '$PCRE2_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: PCRE2 compilation step failed.${w}"
    exit 1
}

cd "$PCRE2_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: PCRE2 installation step failed.${w}"
    exit 1
}

rm -rf "$PCRE2_tar" "$PCRE2_path"

pcre2_version=$(basename "$PCRE2_tar" | cut -f1,2 -d ".")

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
echo "$pcre2_version"
echo "${g}----------------------------${w}"
