#!/bin/bash
# Check R package versions in a nice table for the R412 environment

# Cores
w=$(tput sgr0)
g=$(tput setaf 2)
r=$(tput setaf 1)

# Versão do R
R_ver=$(R --version | grep version | grep R | awk '{print $3}')

# Lista de pacotes a checar
pkgs=(tidyverse ggplot2 dplyr ggrepel devtools argparse fastcluster ape phytools gplots proj4 ragg BiocManager edgeR limma Glimma RCurl annotate GenomicRanges SummarizedExperiment genefilter geneplotter DESeq2 DEXSeq EBSeq qvalue seqLogo EnhancedVolcano Biobase grid)

# Cabeçalho da tabela
echo "${g}"
echo "╔══════════════════════╦═══════════════╗"
echo "║ R                    ║ ${w}$R_ver${g}         ║"
#echo "║ Conda Environment    ║ ${w}R412${g}          ║"
echo "╠══════════════════════╬═══════════════╣"

# Loop pelos pacotes
for pkg in "${pkgs[@]}"; do
    ver=$(R --no-restore -e "packageVersion(\"${pkg}\")" 2>/dev/null | \
          grep '\[1\]' | awk '{print $2}' | sed -r 's/^.{1}//; s/.$//')

    if [ -z "$ver" ]; then
        ver="${r}not installed${g}"
    fi

    printf "║ %-20s ║ ${w}%-13s${g} ║\n" "$pkg" "$ver"
done

# Rodapé
echo "╚══════════════════════╩═══════════════╝"

