#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

git_clone_with_retry() {
    local repo_url="$1"
    local dest_dir="$2"
    local label="$3"
    local max_attempts=5
    local attempt=1

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Cloning $label (attempt $attempt of $max_attempts)..."
        su -c "rm -rf '$dest_dir' && git clone '$repo_url' '$dest_dir'" "$user_name" && return 0
        attempt=$((attempt + 1))
    done

    echo "${r}ERROR: Failed to clone $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "Hpc Grid Runner"
echo "*******************${w}"

git_clone_with_retry "https://github.com/patrick-douglas/HpcGridRunner.git" "/home/$user_name/HpcGridRunner" "HpcGridRunner"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
echo "HpcGridRunner latest GitHub version"
echo "${g}----------------------------${w}"
