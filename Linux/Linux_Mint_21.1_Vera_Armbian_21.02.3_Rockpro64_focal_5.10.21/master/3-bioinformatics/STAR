#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

download_with_retry() {
    local url="$1"
    local output="$2"
    local label="$3"
    local max_attempts=5
    local attempt=1

    echo "${y}Downloading $label source package...${w}"

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Attempt $attempt of $max_attempts..."
        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then
            echo "${g}Download completed successfully.${w}"
            return 0
        fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done

    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "STAR"
echo "*******************${w}"

STAR_url="https://github.com/alexdobin/STAR/archive/refs/tags/2.7.8a.tar.gz"
STAR_tar="/home/$user_name/2.7.8a.tar.gz"
STAR_path1="/home/$user_name/STAR-2.7.8a"
STAR_path2="/home/$user_name/STAR-2.7.8a/bin/Linux_x86_64"

download_with_retry "$STAR_url" "$STAR_tar" "STAR"

su -c "cd ~/ && tar -zxf '$STAR_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the STAR source archive.${w}"
    exit 1
}

if [ ! -d "$STAR_path2" ]; then
    echo "${r}ERROR: STAR binaries directory was not found after extraction.${w}"
    exit 1
fi

sudo cp "$STAR_path2"/STAR* /usr/bin/ || {
    echo "${r}ERROR: Failed to copy STAR binaries to /usr/bin.${w}"
    exit 1
}

rm -rf "$STAR_path1" "$STAR_tar"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
STAR --version
echo "${g}----------------------------${w}"
