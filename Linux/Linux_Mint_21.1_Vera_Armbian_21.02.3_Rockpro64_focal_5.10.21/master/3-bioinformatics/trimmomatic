#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

download_with_retry() {
    local url="$1"; local output="$2"; local label="$3"
    local max_attempts=5; local attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then return 0; fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done
    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "Trimmomatic"
echo "*******************${w}"

rm -rf /home/"$user_name"/Trimmomatic*
Trimmomatic_url="https://github.com/usadellab/Trimmomatic/files/5854859/Trimmomatic-0.39.zip"
Trimmomatic_tar="/home/$user_name/Trimmomatic-0.39.zip"

download_with_retry "$Trimmomatic_url" "$Trimmomatic_tar" "Trimmomatic"

su -c "unzip '$Trimmomatic_tar' -d ~/" "$user_name" || {
    echo "${r}ERROR: Failed to extract the Trimmomatic archive.${w}"
    exit 1
}
rm -rf "$Trimmomatic_tar"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
su -c "java -jar ~/Trimmomatic-0.39/trimmomatic-0.39.jar -version" "$user_name"
echo "${g}----------------------------${w}"
