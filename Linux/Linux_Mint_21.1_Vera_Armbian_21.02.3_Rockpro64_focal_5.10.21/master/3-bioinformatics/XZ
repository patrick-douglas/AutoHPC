#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

# XZ
echo "${y}*******************"
echo "XZ"
echo "*******************${w}"

xz_path="/home/$user_name/xz-5.2.5"
xz_tar="/home/$user_name/xz-5.2.5.tar.gz"
xz_url="https://sonik.dl.sourceforge.net/project/lzmautils/xz-5.2.5.tar.gz"

max_attempts=10
attempt=1
download_success=0

echo "${y}Downloading XZ source package...${w}"

while [ "$attempt" -le "$max_attempts" ]; do
    echo "Attempt $attempt of $max_attempts..."

    su -c "cd ~/ && wget -O '$xz_tar' '$xz_url'" "$user_name"
    wget_exit=$?

    if [ "$wget_exit" -eq 0 ] && [ -s "$xz_tar" ]; then
        echo "${g}Download completed successfully.${w}"
        download_success=1
        break
    else
        echo "${r}Download failed on attempt $attempt.${w}"
        rm -f "$xz_tar"
    fi

    attempt=$((attempt + 1))
done

if [ "$download_success" -ne 1 ]; then
    echo "${r}ERROR: Failed to download XZ after $max_attempts attempts. Installation aborted.${w}"
    exit 1
fi

su -c "cd ~/ && tar -zxf '$xz_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the XZ source archive.${w}"
    exit 1
}

su -c "cd '$xz_path' && ./configure" "$user_name" || {
    echo "${r}ERROR: XZ configuration step failed.${w}"
    exit 1
}

su -c "cd '$xz_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: XZ compilation step failed.${w}"
    exit 1
}

cd "$xz_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: XZ installation step failed.${w}"
    exit 1
}

sudo ldconfig || {
    echo "${r}ERROR: ldconfig failed after XZ installation.${w}"
    exit 1
}

rm -rf "$xz_path" "$xz_tar"

xz_v=$(xz -V | grep xz)

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
echo "$xz_v"
echo "${g}----------------------------${w}"
