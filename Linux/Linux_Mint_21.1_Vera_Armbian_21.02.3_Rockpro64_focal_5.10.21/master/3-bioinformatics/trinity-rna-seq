#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

git_clone_with_retry() {
    local repo_url="$1"
    local dest_dir="$2"
    local label="$3"
    local max_attempts=5
    local attempt=1

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Cloning $label (attempt $attempt of $max_attempts)..."
        su -c "rm -rf '$dest_dir' && git clone --recursive '$repo_url' '$dest_dir'" "$user_name" && return 0
        attempt=$((attempt + 1))
    done

    echo "${r}ERROR: Failed to clone $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "Trinity"
echo "*******************${w}"

sudo apt-fast install -y git autoconf automake libtool pkg-config || {
    echo "${r}ERROR: Failed to install Trinity build dependencies.${w}"
    exit 1
}

trinity_repo="https://github.com/trinityrnaseq/trinityrnaseq.git"
trinity_path="/home/$user_name/trinityrnaseq"
trinity_version="Trinity-v2.15.2"

git_clone_with_retry "$trinity_repo" "$trinity_path" "Trinity"

su -c "cd '$trinity_path' && git checkout '$trinity_version'" "$user_name" || {
    echo "${r}ERROR: Failed to checkout $trinity_version.${w}"
    exit 1
}

su -c "cd '$trinity_path' && git submodule update --init --recursive" "$user_name" || {
    echo "${r}ERROR: Failed to initialize Trinity submodules.${w}"
    exit 1
}

# Fix htslib autotools bootstrap in bamsifter
su -c "cd '$trinity_path' && sed -i 's/autoheader/autoreconf -i/' trinity-plugins/bamsifter/build_htslib.sh && sed -i '/autoconf/d' trinity-plugins/bamsifter/build_htslib.sh" "$user_name" || {
    echo "${r}ERROR: Failed to patch build_htslib.sh.${w}"
    exit 1
}

# Patch bamsifter only if needed
su -c "cd '$trinity_path' && grep -q '^#include <string>' trinity-plugins/bamsifter/sift_bam_max_cov.cpp || sed -i '17i #include <string>' trinity-plugins/bamsifter/sift_bam_max_cov.cpp" "$user_name" || {
    echo "${r}ERROR: Failed to patch sift_bam_max_cov.cpp.${w}"
    exit 1
}

# Patch python shebang if the file exists
if [ -f "$trinity_path/util/support_scripts/trinity_installer.py" ]; then
    sed -i '1c#!/usr/bin/env python3' "$trinity_path/util/support_scripts/trinity_installer.py" || {
        echo "${r}ERROR: Failed to patch trinity_installer.py.${w}"
        exit 1
    }
fi

su -c "cd '$trinity_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: Trinity compilation step failed.${w}"
    exit 1
}

cd "$trinity_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: Trinity installation step failed.${w}"
    exit 1
}

rm -rf "$trinity_path"

echo
echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
/usr/local/bin/Trinity --version 2>/dev/null | grep 'Trinity-v' || /usr/local/bin/Trinity --version
echo "${g}----------------------------${w}"
