#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

download_with_retry() {
    local url="$1"; local output="$2"; local label="$3"
    local max_attempts=5; local attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then return 0; fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done
    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "salmon"
echo "*******************${w}"

salmon_url="https://github.com/COMBINE-lab/salmon/releases/download/v1.10.0/salmon-1.10.0_linux_x86_64.tar.gz"
salmon_tar="/home/$user_name/salmon-1.10.0_linux_x86_64.tar.gz"
salmon_dir="/usr/local/bin/salmon-latest_linux_x86_64"

download_with_retry "$salmon_url" "$salmon_tar" "Salmon"

sudo tar -zxf "$salmon_tar" --directory /usr/local/bin || {
    echo "${r}ERROR: Failed to extract the Salmon archive.${w}"
    exit 1
}

sudo chown -R "$user_name:$user_name" "$salmon_dir" || exit 1
sudo ln -sf "$salmon_dir/bin/salmon" /usr/local/bin/salmon || {
    echo "${r}ERROR: Failed to create the Salmon symlink.${w}"
    exit 1
}

rm -rf "$salmon_tar"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
/usr/local/bin/salmon -v
echo "${g}----------------------------${w}"
