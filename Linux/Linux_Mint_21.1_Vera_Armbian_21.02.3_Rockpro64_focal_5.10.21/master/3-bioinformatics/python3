#!/bin/bash
# This script is executed through a primary script.

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument:${y} -u | User name | <string>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

# Python
echo "${y}*******************"
echo "python"
echo "*******************${w}"

python_path="/home/$user_name/Python-3.10.2"
python_tar="/home/$user_name/Python-3.10.2.tar.xz"
python_url="https://www.python.org/ftp/python/3.10.2/Python-3.10.2.tar.xz"

# Download with retries
max_attempts=10
attempt=1
download_success=0

echo "${y}Downloading Python source package...${w}"

while [ "$attempt" -le "$max_attempts" ]; do
    echo "Attempt $attempt of $max_attempts..."

    su -c "cd ~/ && wget -O '$python_tar' '$python_url'" "$user_name"
    wget_exit=$?

    if [ "$wget_exit" -eq 0 ] && [ -s "$python_tar" ]; then
        echo "${g}Download completed successfully.${w}"
        download_success=1
        break
    else
        echo "${r}Download failed on attempt $attempt.${w}"
        rm -f "$python_tar"
    fi

    attempt=$((attempt + 1))
done

if [ "$download_success" -ne 1 ]; then
    echo "${r}ERROR: Failed to download Python after $max_attempts attempts. Installation aborted.${w}"
    exit 1
fi

su -c "cd ~/ && tar -xf '$python_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the Python source archive.${w}"
    exit 1
}

su -c "cd '$python_path' && ./configure --enable-optimizations" "$user_name" || {
    echo "${r}ERROR: Configuration step failed.${w}"
    exit 1
}

su -c "cd '$python_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: Build step failed.${w}"
    exit 1
}

cd "$python_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: Installation step failed.${w}"
    exit 1
}

python_version=$(python3 --version)
ln -fs /usr/local/bin/python3.10 /usr/local/bin/python

su -c 'pip3 install -U setuptools' "$user_name"
su -c 'pip3 install numpy' "$user_name"
su -c 'pip3 install --upgrade pip' "$user_name"
su -c 'pip3 install biopython' "$user_name"

rm -rf "$python_path" "$python_tar"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
echo "$python_version"
echo "${g}----------------------------${w}"
