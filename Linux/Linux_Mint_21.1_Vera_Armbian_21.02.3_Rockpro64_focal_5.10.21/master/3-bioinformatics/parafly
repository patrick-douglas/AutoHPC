#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

download_with_retry() {
    local url="$1"; local output="$2"; local label="$3"
    local max_attempts=5; local attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        su -c "cd '/home/$user_name' && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then return 0; fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done
    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "Parafly"
echo "*******************${w}"

parafly_path="/home/$user_name/parafly-r2013-01-21"
parafly_tar="/home/$user_name/parafly-r2013-01-21.tgz"
parafly_url="https://master.dl.sourceforge.net/project/parafly/parafly-r2013-01-21.tgz"

download_with_retry "$parafly_url" "$parafly_tar" "Parafly"

su -c "cd '/home/$user_name' && tar -zxf '$parafly_tar'" "$user_name" || exit 1
su -c "cd '$parafly_path' && ./configure" "$user_name" || exit 1
su -c "cd '$parafly_path' && make -j '$threads'" "$user_name" || exit 1
cd "$parafly_path" && sudo make install -j "$threads" || exit 1

rm -rf "$parafly_path" "$parafly_tar"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
echo "parafly-r2013-01-21"
echo "${g}----------------------------${w}"
