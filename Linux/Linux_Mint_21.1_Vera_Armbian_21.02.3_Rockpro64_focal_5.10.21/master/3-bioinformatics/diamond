#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

download_with_retry() {
    local url="$1"; local output="$2"; local label="$3"
    local max_attempts=5; local attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then return 0; fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done
    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "diamond"
echo "*******************${w}"

diamond_url="https://github.com/bbuchfink/diamond/releases/download/v2.1.20/diamond-linux64.tar.gz"
diamond_tar="/home/$user_name/diamond-linux64.tar.gz"
diamond_bin="/home/$user_name/diamond"

download_with_retry "$diamond_url" "$diamond_tar" "DIAMOND"

su -c "cd ~/ && tar -zxf '$diamond_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the DIAMOND archive.${w}"
    exit 1
}

sudo cp "$diamond_bin" /usr/local/bin/diamond || {
    echo "${r}ERROR: Failed to install the DIAMOND binary.${w}"
    exit 1
}
sudo chmod +x /usr/local/bin/diamond

rm -rf "$diamond_bin" "$diamond_tar"

echo
echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
/usr/local/bin/diamond --version
echo "${g}----------------------------${w}"
