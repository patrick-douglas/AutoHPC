#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

# cmake
echo "${y}*******************"
echo "cmake"
echo "*******************${w}"

cmake_tar="/home/$user_name/cmake-3.23.0-rc1.tar.gz"
cmake_path="/home/$user_name/cmake-3.23.0-rc1"
cmake_url="https://github.com/Kitware/CMake/releases/download/v3.23.0-rc1/cmake-3.23.0-rc1.tar.gz"

max_attempts=10
attempt=1
download_success=0

echo "${y}Downloading CMake source package...${w}"

while [ "$attempt" -le "$max_attempts" ]; do
    echo "Attempt $attempt of $max_attempts..."

    su -c "cd ~/ && wget -O '$cmake_tar' '$cmake_url'" "$user_name"
    wget_exit=$?

    if [ "$wget_exit" -eq 0 ] && [ -s "$cmake_tar" ]; then
        echo "${g}Download completed successfully.${w}"
        download_success=1
        break
    else
        echo "${r}Download failed on attempt $attempt.${w}"
        rm -f "$cmake_tar"
    fi

    attempt=$((attempt + 1))
done

if [ "$download_success" -ne 1 ]; then
    echo "${r}ERROR: Failed to download CMake after $max_attempts attempts. Installation aborted.${w}"
    exit 1
fi

su -c "cd ~/ && tar -zxf '$cmake_tar'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the CMake source archive.${w}"
    exit 1
}

su -c "cd '$cmake_path' && ./configure" "$user_name" || {
    echo "${r}ERROR: CMake configuration step failed.${w}"
    exit 1
}

su -c "cd '$cmake_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: CMake compilation step failed.${w}"
    exit 1
}

cd "$cmake_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: CMake installation step failed.${w}"
    exit 1
}

rm -rf "$cmake_path" "$cmake_tar"
cd

echo "${g}"
echo "---------------------------------------------------"
echo "          Currently installed version:"
echo "---------------------------------------------------${w}"
cmake --version
echo "${g}---------------------------------------------------${w}"
