#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

download_with_retry() {
    local url="$1"; local output="$2"; local label="$3"
    local max_attempts=5; local attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then return 0; fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done
    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "FastQC"
echo "*******************${w}"

FastQC_zip="/home/$user_name/fastqc_v0.12.1.zip"
FastQC_path="/home/$user_name/FastQC"
FastQC_url="https://www.bioinformatics.babraham.ac.uk/projects/fastqc/fastqc_v0.12.1.zip"

rm -rf "$FastQC_path"
download_with_retry "$FastQC_url" "$FastQC_zip" "FastQC"

su -c "cd ~/ && unzip '$FastQC_zip'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the FastQC archive.${w}"
    exit 1
}
su -c "chmod +x '$FastQC_path/fastqc'" "$user_name" || {
    echo "${r}ERROR: Failed to make FastQC executable.${w}"
    exit 1
}

rm -rf "$FastQC_zip"

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
"$FastQC_path/fastqc" -v
echo "${g}----------------------------${w}"
