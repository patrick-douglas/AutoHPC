#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

download_with_retry() {
    local url="$1"
    local output="$2"
    local label="$3"
    local max_attempts=10
    local attempt=1

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        wget -O "$output" "$url"
        if [ $? -eq 0 ] && [ -s "$output" ]; then
            return 0
        fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done

    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "ncbi-blast+"
echo "*******************${w}"

sudo apt-fast install -y alien || {
    echo "${r}ERROR: Failed to install alien.${w}"
    exit 1
}

blast_base_url="https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/LATEST"
blast_index=$(wget -qO- "$blast_base_url/") || {
    echo "${r}ERROR: Failed to retrieve the BLAST download index.${w}"
    exit 1
}

blast_rpm_name=$(echo "$blast_index" | grep -oE 'ncbi-blast-[^"]+\.x86_64\.rpm' | grep -v '\.src\.rpm' | head -n 1)

if [ -z "$blast_rpm_name" ]; then
    echo "${r}ERROR: Could not determine the latest BLAST x86_64 RPM filename from the download index.${w}"
    exit 1
fi

blast_url="$blast_base_url/$blast_rpm_name"
blast_rpm="/home/$user_name/$blast_rpm_name"

download_with_retry "$blast_url" "$blast_rpm" "ncbi-blast+"

echo "${y}**************************************************************"
echo "Creating a ncbi-blast+ .deb file, this may take a long time..."
echo "**************************************************************${w}"

cd "/home/$user_name" && alien -v -d "$blast_rpm" || {
    echo "${r}ERROR: Failed to create the ncbi-blast+ Debian package.${w}"
    exit 1
}

blast_deb=$(find "/home/$user_name" -maxdepth 1 -type f -name "ncbi-blast*.deb" | head -n 1)

if [ -z "$blast_deb" ]; then
    echo "${r}ERROR: Could not find the generated ncbi-blast+ Debian package.${w}"
    exit 1
fi

echo "${y}************************************************"
echo "Installing ncbi-blast+, this may take a long time"
echo "************************************************${w}"

sudo dpkg -i "$blast_deb" || {
    echo "${r}ERROR: Failed to install ncbi-blast+.${w}"
    exit 1
}

rm -f "/home/$user_name"/ncbi-blast*.rpm "/home/$user_name"/ncbi-blast*.deb

echo "${g}"
echo "----------------------------"
echo "Currently installed version:"
echo "----------------------------${w}"
blastx -version | grep Package
echo "${g}----------------------------${w}"
