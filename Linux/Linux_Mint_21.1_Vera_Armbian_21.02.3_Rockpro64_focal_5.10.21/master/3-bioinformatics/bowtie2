#!/bin/bash
# This script is executed through a primary script

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)

USAGE="USAGE: $0 -u <username>"

if [ "$#" -lt 1 ]; then
    echo -e "$USAGE"
    exit 1
fi

while getopts "u:" option; do
    case "${option}" in
        u) user_name=$OPTARG ;;
    esac
done

if [ -z "$user_name" ]; then
    echo -e "${r}Error: missing argument ${y}-u <username>${w}"
    echo -e "$USAGE"
    exit 1
fi

threads=$(nproc)

download_with_retry() {
    local url="$1"; local output="$2"; local label="$3"
    local max_attempts=5; local attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Downloading $label (attempt $attempt of $max_attempts)..."
        su -c "cd ~/ && wget -O '$output' '$url'" "$user_name"
        if [ $? -eq 0 ] && [ -s "$output" ]; then return 0; fi
        rm -f "$output"
        attempt=$((attempt + 1))
    done
    echo "${r}ERROR: Failed to download $label after $max_attempts attempts. Installation aborted.${w}"
    exit 1
}

echo "${y}*******************"
echo "Bowtie2"
echo "*******************${w}"

bowtie_path="/home/$user_name/bowtie2-2.4.5"
bowtie_url="https://github.com/BenLangmead/bowtie2/archive/refs/tags/v2.4.5.tar.gz"
bowtie_zip="/home/$user_name/v2.4.5.tar.gz"

download_with_retry "$bowtie_url" "$bowtie_zip" "Bowtie2"

su -c "cd ~/ && tar -zxf '$bowtie_zip'" "$user_name" || {
    echo "${r}ERROR: Failed to extract the Bowtie2 source archive.${w}"
    exit 1
}
su -c "cd '$bowtie_path' && make -j '$threads'" "$user_name" || {
    echo "${r}ERROR: Bowtie2 compilation step failed.${w}"
    exit 1
}
cd "$bowtie_path" && sudo make install -j "$threads" || {
    echo "${r}ERROR: Bowtie2 installation step failed.${w}"
    exit 1
}

rm -rf "$bowtie_path" "$bowtie_zip"

echo "${g}"
echo "-----------------------------"
echo "Currently installed version:"
echo "-----------------------------${w}"
bowtie2 --version | head -n 1
echo "${g}-----------------------------${w}"
