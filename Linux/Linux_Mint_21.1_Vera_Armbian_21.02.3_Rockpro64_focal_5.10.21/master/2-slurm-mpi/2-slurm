#!/bin/bash
# This script is executed through a primary script
# Configures SLURM controller on the master node

set -Eeuo pipefail

w=$(tput sgr0)
r=$(tput setaf 1)
g=$(tput setaf 2)
y=$(tput setaf 3)
p=$(tput setaf 5)

LOG_FILE="/var/log/slurm_controller_install.log"
mkdir -p "$(dirname "$LOG_FILE")"
touch "$LOG_FILE"
exec > >(tee -a "$LOG_FILE") 2>&1

trap 'echo "${r}ERROR: Installation failed at line $LINENO. Check $LOG_FILE for details.${w}"' ERR

USAGE="$0 -c <clustername> -u <username>"

require_root() {
    if [[ $(/usr/bin/id -u) -ne 0 ]]; then
        echo "${y}-----------------------------------------------------------------------------------"
        echo "This script requires root privileges. Please run ${w}sudo su${y} or ${w}sudo -i${y} before running it."
        echo "For example: ${w}sudo $0 -c <clustername> -u <username>${y}"
        echo "-----------------------------------------------------------------------------------${w}"
        exit 1
    fi
}

parse_args() {
    if [ "$#" -lt 4 ]; then
        echo -e "$USAGE"
        exit 1
    fi

    while getopts "c:u:" option; do
        case "${option}" in
            c) cluster_name=${OPTARG} ;;
            u) user_name=${OPTARG} ;;
            *) echo -e "$USAGE"; exit 1 ;;
        esac
    done

    if [ -z "${cluster_name:-}" ]; then
        echo -e "${r}Error: missing argument ${y}-c <clustername>${w}"
        echo -e "$USAGE"
        exit 1
    fi

    if [ -z "${user_name:-}" ]; then
        echo -e "${r}Error: missing argument ${y}-u <username>${w}"
        echo -e "$USAGE"
        exit 1
    fi
}

info() {
    echo "${g}$*${w}"
}

warn() {
    echo "${y}$*${w}"
}

die() {
    echo "${r}ERROR: $*${w}"
    exit 1
}

download_with_retry() {
    local url="$1"
    local output="$2"
    local label="$3"
    local max_attempts=5
    local attempt=1

    warn "Downloading $label..."

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Attempt $attempt of $max_attempts..."
        wget -O "$output" "$url" && [ -s "$output" ] && {
            info "Download completed successfully."
            return 0
        }
        rm -f "$output"
        attempt=$((attempt + 1))
        sleep 3
    done

    die "Failed to download $label after $max_attempts attempts. Installation aborted."
}

git_clone_with_retry() {
    local repo_url="$1"
    local dest_dir="$2"
    local label="$3"
    local max_attempts=5
    local attempt=1

    while [ "$attempt" -le "$max_attempts" ]; do
        echo "Cloning $label (attempt $attempt of $max_attempts)..."
        rm -rf "$dest_dir"
        git clone "$repo_url" "$dest_dir" && return 0
        attempt=$((attempt + 1))
        sleep 3
    done

    die "Failed to clone $label after $max_attempts attempts. Installation aborted."
}

check_service_active() {
    local service_name="$1"
    systemctl is-active --quiet "$service_name" || die "$service_name is not active."
}

run_expect_script() {
    local file_path="$1"
    expect "$file_path" || die "Failed to execute expect script: $file_path"
}

create_file_from_here_doc() {
    local path="$1"
    cat > "$path"
    chmod +x "$path"
}

configure_mariadb_for_slurm() {
    local exp_file="/storage/expect_mariadb.exp"

    create_file_from_here_doc "$exp_file" <<'EOF'
#!/usr/bin/expect
spawn mysql -u root
expect {
    "MariaDB" {}
    "mysql>" {}
    timeout { exit 1 }
}
send "CREATE DATABASE IF NOT EXISTS slurm_acct_db;\r"
expect "mysql>"
send "CREATE USER IF NOT EXISTS 'slurm'@'localhost' IDENTIFIED BY 'slurmdbpass';\r"
expect "mysql>"
send "GRANT USAGE ON *.* TO 'slurm'@'localhost';\r"
expect "mysql>"
send "GRANT ALL PRIVILEGES ON slurm_acct_db.* TO 'slurm'@'localhost';\r"
expect "mysql>"
send "FLUSH PRIVILEGES;\r"
expect "mysql>"
send "exit\r"
expect eof
EOF

    run_expect_script "$exp_file"
    rm -f "$exp_file"
}

configure_slurm_accounting() {
    local exp_file="/storage/slurm_expect.exp"

    create_file_from_here_doc "$exp_file" <<EOF
#!/usr/bin/expect
spawn sacctmgr add cluster $cluster_name
expect {
    -re "Would you like to commit changes.*" { send "y\r" }
    eof
}
EOF
    run_expect_script "$exp_file"

    create_file_from_here_doc "$exp_file" <<'EOF'
#!/usr/bin/expect
spawn sacctmgr add account compute-account description="Compute accounts" Organization=OurOrg
expect {
    -re "Would you like to commit changes.*" { send "y\r" }
    eof
}
EOF
    run_expect_script "$exp_file"

    create_file_from_here_doc "$exp_file" <<EOF
#!/usr/bin/expect
spawn sacctmgr create user $user_name account=compute-account adminlevel=None
expect {
    -re "Would you like to commit changes.*" { send "y\r" }
    eof
}
EOF
    run_expect_script "$exp_file"

    rm -f "$exp_file"
}

append_node_to_slurm_conf() {
    local sockets cores_per_socket threads_per_core realmem
    sockets=$(lscpu | awk -F: '/Socket\(s\)/ {gsub(/ /,"",$2); print $2}')
    threads_per_core=$(lscpu | awk -F: '/Thread\(s\) per core/ {gsub(/ /,"",$2); print $2}')
    cores_per_socket=$(lscpu | awk -F: '/Core\(s\) per socket/ {gsub(/ /,"",$2); print $2}')
    realmem=$(free -m | awk '/Mem:/ {print $2}')

    echo "NodeName=$HOSTNAME Sockets=$sockets CoresPerSocket=$cores_per_socket ThreadsPerCore=$threads_per_core RealMemory=$realmem State=UNKNOWN" >> /etc/slurm/slurm.conf
}

main() {
    require_root
    parse_args "$@"

    local threads slurm_bz2 slurm_dir slurm_deb slurm_url slurm_pkg_name
    threads=$(nproc)
    slurm_bz2="/root/slurm-22.05.0-0rc1.tar.bz2"
    slurm_dir="/root/slurm-22.05.0-0rc1"
    slurm_deb="/root/slurm-22.05.0-0rc1_1.0_amd64.deb"
    slurm_url="https://download.schedmd.com/slurm/slurm-22.05.0-0rc1.tar.bz2"
    slurm_pkg_name="slurm-22.05.0-0rc1"

    info "-----------------------------------------------------------------------------------"
    info "------------------------------ Configuring SLURM ----------------------------------"
    info "-----------------------------------------------------------------------------------"
    echo "${g}Cluster name:${w}"
    echo "$cluster_name"
    echo "${g}User name:${w}"
    echo "$user_name"
    info "-----------------------------------------------------------------------------------"

    warn "Cleaning previous temporary files..."
    rm -rf /storage /root/slurm*

    warn "Updating package lists..."
    apt-fast update

    warn "Installing required packages..."
    apt-fast install -y \
        git gcc make ruby ruby-dev libpam0g-dev \
        libmariadb-dev libmariadb-dev-compat mariadb-server \
        libmunge-dev libmunge2 munge libdbus-1-dev \
        glib-2.0 libperl-dev libgtk2.0-dev expect

    gem install fpm || die "Failed to install fpm via RubyGems."

    mkdir -p /storage
    cd /storage

    git_clone_with_retry "https://github.com/patrick-douglas/ubuntu-slurm.git" "/storage/ubuntu-slurm" "ubuntu-slurm"

    warn "Enabling and starting MUNGE..."
    systemctl enable munge
    systemctl restart munge
    check_service_active "munge"

    info "-----------------------------"
    info "Testing MUNGE..."
    info "-----------------------------"
    munge -n | unmunge | grep STATUS || die "MUNGE test failed."

    warn "Enabling and starting MariaDB..."
    systemctl enable mariadb.service
    systemctl restart mariadb.service
    check_service_active "mariadb"

    warn "Configuring MariaDB for SLURM accounting..."
    configure_mariadb_for_slurm

    warn "Downloading and building SLURM..."
    download_with_retry "$slurm_url" "$slurm_bz2" "SLURM"
    cd /root
    tar -xjf "$slurm_bz2"
    cd "$slurm_dir"

    ./configure \
        --prefix=/tmp/slurm-build \
        --sysconfdir=/etc/slurm \
        --enable-pam \
        --with-pam_dir=/lib/x86_64-linux-gnu/security/ \
        --without-shared-libslurm

    make -j "$threads"
    make contrib -j "$threads"
    make install -j "$threads"

    cd /root
    fpm -s dir -t deb -v 1.0 -n "$slurm_pkg_name" --prefix=/usr -C /tmp/slurm-build .
    dpkg -i --force-all "$slurm_deb"
    rm -f "$slurm_deb"

    id slurm >/dev/null 2>&1 || useradd slurm

    mkdir -p /etc/slurm /etc/slurm/prolog.d /etc/slurm/epilog.d \
             /var/spool/slurm/ctld /var/spool/slurm/d /var/log/slurm

    chown slurm /var/spool/slurm/ctld /var/spool/slurm/d /var/log/slurm

    cp /storage/ubuntu-slurm/slurmdbd.service /etc/systemd/system/
    cp /storage/ubuntu-slurm/slurmctld.service /etc/systemd/system/
    cp /storage/ubuntu-slurm/slurmd.service /etc/systemd/system/
    cp /storage/ubuntu-slurm/slurm.conf /etc/slurm/
    cp /storage/ubuntu-slurm/slurmdbd.conf /etc/slurm/
    cp /storage/ubuntu-slurm/cgroup.conf /etc/slurm/cgroup.conf

    chown slurm /etc/slurm/slurmdbd.conf
    chmod 600 /etc/slurm/slurmdbd.conf

    append_node_to_slurm_conf

    systemctl daemon-reload

    warn "Starting slurmdbd..."
    systemctl enable slurmdbd
    systemctl restart slurmdbd
    check_service_active "slurmdbd"

    warn "Starting slurmctld..."
    systemctl enable slurmctld
    systemctl restart slurmctld
    check_service_active "slurmctld"

    sinfo || die "sinfo failed after starting slurmctld."

    warn "Configuring initial SLURM cluster/account/user..."
    configure_slurm_accounting

    warn "Restarting SLURM services..."
    systemctl restart slurmctld
    systemctl enable slurmd
    systemctl restart slurmd
    check_service_active "slurmd"

    if command -v nvidia-smi >/dev/null 2>&1; then
        nvidia-smi -r || true
    fi

    info "------------------------------------------------------------------------------------------------"
    sinfo -l -N
    info "------------------------------------------------------------------------------------------------"

    rm -rf "$slurm_dir" "$slurm_bz2"

    echo "${g}"
    echo "----------------------------------------------------------------------------------"
    echo "-------------------------- Slurm configured successfully -------------------------"
    echo "----------------------------------------------------------------------------------${w}"
    echo "Log file: $LOG_FILE"
}

main "$@"
